{
  "name": "tome-builder",
  "displayName": "Realm Tome Builder",
  "description": "AI-powered custom DSL assistant for creating Realm Tomes via MCP",
  "version": "0.1.0",
  "publisher": "realm",
  "repository": {
    "type": "git",
    "url": "https://github.com/spellshift/realm.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "eldritch",
        "aliases": [
          "Eldritch",
          "eldritch"
        ],
        "extensions": [
          ".tome",
          ".eldritch"
        ],
        "configuration": "./syntaxes/eldritch.configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "eldritch",
        "scopeName": "source.eldritch",
        "path": "./syntaxes/eldritch.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "tomeBuilder.registerMcp",
        "title": "Tome Builder: Register MCP Server for AI extensions"
      }
    ],
    "mcpServers": {
      "tome-builder": {
        "command": "node",
        "args": [
          "./mcp-server/dist/index.js"
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-mcp": "cd mcp-server && npm install && npm run build"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
